
[global]
    # Display
    monitor = 0
    follow = mouse
    
    # Geometry
    width = (300, 400)
    height = (0, 300)
    origin = top-right
    offset = (20, 50)
    
    # Progress bar
    progress_bar = true
    progress_bar_height = 14
    progress_bar_frame_width = 1
    progress_bar_min_width = 300
    progress_bar_max_width = 300
    
    # Appearance
    transparency = 10
    separator_height = 2
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 16
    frame_width = 2
    separator_color = frame
    sort = yes
    idle_threshold = 120
    
    # Text
    font = GohuFont 11 Nerd Font Mono 11
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    
    # Icons
    icon_position = left
    min_icon_size = 48
    max_icon_size = 64
    icon_path = /usr/share/icons/Papirus/48x48/status/:/usr/share/icons/Papirus/48x48/devices/:/usr/share/icons/Adwaita/48x48/status/:/usr/share/icons/Adwaita/48x48/devices/

    # History
    sticky_history = yes
    history_length = 20
    
    # Sound script
    script = ~/.config/dunst/dunst_sounds.sh
    title = Dunst
    class = Dunst
    corner_radius = 12
    ignore_dbusclose = false
    
    # Mouse
    mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#1e1e2e"
    foreground = "#7fbbb3"
    frame_color = "#7fbbb3"
    timeout = 4
    
[urgency_normal]
    background = "#1e1e2e"
    foreground = "#a7c080"
    frame_color = "#a7c080"
    timeout = 6

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#e67e80"
    frame_color = "#e67e80"
    timeout = 10
    
# Custom rules
[battery_low]
    appname = "Battery Low"
    urgency = normal
    background = "#1e1e2e"
    foreground = "#fab387"
    frame_color = "#fab387"
    timeout = 8

[battery_critical]
    appname = "Battery Critical"
    urgency = critical
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8"
    timeout = 0
